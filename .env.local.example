# Copy to .env.local and fill in values.

# Anthropic — required for /api/chat and /api/content/generate
ANTHROPIC_API_KEY=

# OpenAI — GPT Image / DALL·E for draft post visuals (optional but recommended)
OPENAI_API_KEY=
# Image model: gpt-image-1.5, gpt-image-1, gpt-image-2, dall-e-2, etc.
OPENAI_IMAGE_MODEL=gpt-image-1

# Public app URL — image URLs + Notion worker generateDraftContent (e.g. http://localhost:3000 in dev)
NOTIONCHELLA_APP_URL=

# Notion internal integration secret — required for /api/notion/setup
NOTION_API_KEY=

# Parent page ID (UUID or full notion.so URL containing the UUID).
# The integration must be invited to this page.
NOTION_PAGE_ID=

# Notion Workers CLI (sandbox deploy) — personal access token + workspace ID
# https://developers.notion.com/guides/get-started/personal-access-tokens
NOTION_API_TOKEN=
NOTION_WORKSPACE_ID=

# Vercel Sandbox (required on Vercel for ntn workers deploy from /api/chat/deploy)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Optional: protect POST /api/deploy-notion-worker (test-deploy.mjs)
DEPLOY_TRIGGER_SECRET=

# Eventbrite / Spotify / Instagram — passed through to the deployed worker
EVENTBRITE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
