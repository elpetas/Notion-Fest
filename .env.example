# Notion CLI / Workers (required for deploy)
# Create a token with access to your workspace per Notion authentication docs.
NOTION_API_TOKEN=
NOTION_WORKSPACE_ID=

# Shared secret for POST /api/deploy-notion-worker (Authorization: Bearer <value>)
DEPLOY_TRIGGER_SECRET=

# Vercel Sandbox — only needed for local runs of the deploy route.
# On Vercel production, OIDC authenticates the Sandbox SDK automatically.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Eventbrite — personal OAuth token for the Eventbrite API.
# Get one at: eventbrite.com > Account Settings > Developer Links > API Keys
EVENTBRITE_API_KEY=

# Spotify — client credentials for artist search and roster enrichment.
# 1. Go to developer.spotify.com/dashboard and create an app (any name/description).
# 2. Copy Client ID and Client Secret.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Instagram API with Instagram Login (graph.instagram.com — not graph.facebook.com).
# 1. Professional account + Meta app with Instagram Login product.
# 2. Generate token in App Dashboard → API setup with Instagram login.
# 3. Permissions: business_basic, content_publish, manage_insights,
#    manage_comments, manage_messages (for engagement funnel).
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Content generation (draft posts + images) — used by /api/content/generate and the worker tool.
# Anthropic: same key as /api/chat. OpenAI: GPT Image models (gpt-image-1.5, gpt-image-1, …).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
# Public origin of this app (for worker generateDraftContent proxy + cached image URLs).
NOTIONCHELLA_APP_URL=
